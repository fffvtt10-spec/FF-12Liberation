rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return isSignedIn() && exists(userPath());
    }

    function isMestre() {
      return userExists() && get(userPath()).data.role == 'mestre';
    }

    // Admin do painel (criar/banir contas). Aprovações in-game usam role "mestre" em /users.
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'fffvtt10@gmail.com';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function playerSessionFieldsOnly() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'connected_players',
          'equipes',
          'participantes',
          'bencao_deuses',
          'pings',
          'tokens',
          'painted_groups',
          'latest_roll'
        ]);
    }

    // Bazar: verifica que APENAS character_sheet.inventory.gil mudou usando diff aninhado.
    // Mais robusto do que comparar Maps inteiros com ==.
    function isPlayerGilUpdate() {
      let topChanged = request.resource.data.diff(resource.data).affectedKeys();
      return isOwner(charId)
        && topChanged.hasOnly(['character_sheet'])
        && request.resource.data.character_sheet
              .diff(resource.data.character_sheet).affectedKeys().hasOnly(['inventory'])
        && request.resource.data.character_sheet.inventory
              .diff(resource.data.character_sheet.inventory).affectedKeys().hasOnly(['gil']);
    }

    // Sincronização de classe: atualiza campo 'class' (top-level) + character_sheet.basic_info.class
    function isPlayerClassSync() {
      let topChanged = request.resource.data.diff(resource.data).affectedKeys();
      return isOwner(charId)
        && topChanged.hasOnly(['class', 'character_sheet'])
        && request.resource.data.character_sheet
              .diff(resource.data.character_sheet).affectedKeys().hasOnly(['basic_info'])
        && request.resource.data.character_sheet.basic_info
              .diff(resource.data.character_sheet.basic_info).affectedKeys().hasOnly(['class'])
        && request.resource.data.class is string
        && request.resource.data.class == request.resource.data.character_sheet.basic_info.class;
    }

    function characterSheetCoreUnchanged() {
      let before = resource.data.character_sheet;
      let after = request.resource.data.character_sheet;
      return after.basic_info.level == before.basic_info.level
        && after.basic_info.experience == before.basic_info.experience
        && after.basic_info.race == before.basic_info.race
        && after.basic_info.character_name == before.basic_info.character_name
        && after.attributes == before.attributes
        && after.status == before.status
        && after.job_system == before.job_system;
    }

    function characterSheetOnlyInventoryChanged() {
      let before = resource.data.character_sheet;
      let after = request.resource.data.character_sheet;
      return after.basic_info == before.basic_info
        && after.attributes == before.attributes
        && after.status == before.status
        && after.job_system == before.job_system
        && after.equipment == before.equipment;
    }

    function playerCanUpdateOwnCharacter() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isOwner(charId)
        && !changed.hasAny(['uid', 'email', 'createdAt', 'name', 'race', 'gender'])
        && changed.hasOnly(['character_sheet'])
        && (characterSheetCoreUnchanged() || characterSheetOnlyInventoryChanged());
    }

    // Compra no Bazar: bazar → requested. Exige que o item ainda não tenha dono (ownerId == null).
    function isPlayerBazarPurchase() {
      return isSignedIn()
        && resource.data.status == 'bazar'
        && resource.data.ownerId == null
        && request.resource.data.status == 'requested'
        && request.resource.data.ownerId == request.auth.uid;
    }

    // Equipar do vault: o jogador só pode equipar itens que já são dele (ownerId == auth.uid).
    function isPlayerEquipFromVault() {
      return isSignedIn()
        && resource.data.status == 'vault'
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'equipped'
        && request.resource.data.ownerId == request.auth.uid;
    }

    function isPlayerUnequipToVault() {
      return isSignedIn()
        && resource.data.status == 'equipped'
        && request.resource.data.status == 'vault'
        && resource.data.ownerId == request.auth.uid;
    }

    function playerCanUpdateGameItem() {
      return isPlayerBazarPurchase()
        || isPlayerEquipFromVault()
        || isPlayerUnequipToVault();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isMestre() || isAdmin();
      allow create: if isAdmin()
        && request.resource.data.uid == userId
        && request.resource.data.role in ['jogador', 'mestre']
        && request.resource.data.keys().hasAll(['email', 'role', 'uid', 'active']);
      allow update: if isAdmin()
        && request.resource.data.role in ['jogador', 'mestre']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'active']);
      allow delete: if isAdmin();
    }

    match /characters/{charId} {
      allow read: if isSignedIn();
      allow create: if isOwner(charId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'name', 'character_sheet']);
      allow update: if isMestre()
        || isAdmin()
        || isPlayerGilUpdate()
        || isPlayerClassSync()
        || playerCanUpdateOwnCharacter();
      allow delete: if isAdmin();
    }

    match /mestres_profiles/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid) && isMestre();
      allow delete: if isMestre() || isAdmin();
    }

    match /missoes/{missaoId} {
      allow read: if isSignedIn();
      allow create, delete: if isMestre();
      allow update: if isMestre()
        || (
          isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['candidatos'])
        );
    }

    match /sessoes/{sessaoId} {
      allow read: if isSignedIn();
      allow create, delete: if isMestre();
      allow update: if isMestre() || (isSignedIn() && playerSessionFieldsOnly());

      match /mercado_lanternas/{trocaId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.remetenteUid == request.auth.uid
          && request.resource.data.status == 'pendente_mestre';
        allow update, delete: if isMestre();
      }

      match /team_chats/{teamId}/messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.keys().hasAll(['senderName', 'senderUid', 'content', 'createdAt']);
        allow update, delete: if isMestre();
      }
    }

    match /disponibilidades/{docId} {
      allow read: if isSignedIn();
      allow write: if isMestre();
    }

    match /agenda/{docId} {
      allow read: if isSignedIn();
      allow write: if isMestre();
    }

    match /game_items/{itemId} {
      allow read: if isSignedIn();
      allow create, delete: if isMestre();
      allow update: if isMestre() || playerCanUpdateGameItem();
    }

    match /mercado_lanternas/{trocaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.remetenteUid == request.auth.uid
        && request.resource.data.status == 'pendente_mestre';
      allow update, delete: if isMestre();
    }

    match /guild_fraternidade/{docId} {
      allow read: if isSignedIn();
      allow write: if isMestre();
    }

    match /vtt_library/{docId} {
      allow read: if isSignedIn();
      allow write: if isMestre();
    }

    match /resenhas/{docId} {
      allow read: if isSignedIn();
      allow write: if isMestre();
    }

    match /bestiary/{docId} {
      allow read: if isSignedIn();
      allow write: if isMestre();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
