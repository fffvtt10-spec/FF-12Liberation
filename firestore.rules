rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return isSignedIn() && exists(userPath());
    }

    function isMestre() {
      return userExists() && get(userPath()).data.role == 'mestre';
    }

    // Admin do painel (criar/banir contas). Aprovações in-game usam role "mestre" em /users.
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email_verified == true
        && request.auth.token.email == 'fffvtt10@gmail.com';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function playerSessionFieldsOnly() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      // Campos permitidos no total
      let allowedFields = ['connected_players', 'equipes', 'participantes',
                           'bencao_deuses', 'pings', 'tokens', 'painted_groups', 'latest_roll'];
      // Campos de interação in-game que exigem que o jogador já esteja conectado
      let gameFields = ['bencao_deuses', 'pings', 'tokens', 'painted_groups', 'latest_roll'];
      return isSignedIn()
        && changed.hasOnly(allowedFields)
        && (
          // Conexão/desconexão e registro em arenas: qualquer jogador logado pode fazer
          !changed.hasAny(gameFields)
          ||
          // Interações in-game: exige que o UID do jogador esteja em connected_players
          request.auth.uid in resource.data.connected_players
        );
    }

    // Jogador pode atualizar sua própria ficha, desde que não altere progressão controlada pelo Mestre.
    // charId é recebido como parâmetro explícito para evitar o bug de escopo em funções do nível raiz.
    // Usa diff aninhado para evitar comparação Map==Map que falha em estruturas complexas (arrays, etc.)
    function playerCanUpdateOwnCharacter(charId) {
      let docChanged = request.resource.data.diff(resource.data).affectedKeys();
      let sheetChanged = request.resource.data.character_sheet
                           .diff(resource.data.character_sheet).affectedKeys();
      return isOwner(charId)
        // Só 'character_sheet' (e opcionalmente 'class') mudam no documento
        && docChanged.hasOnly(['character_sheet', 'class'])
        // Campos de identidade no nível do documento não mudam
        && !docChanged.hasAny(['uid', 'email', 'createdAt', 'name', 'race', 'gender'])
        // Atributos e sistema de jobs são controlados pelo Mestre, não pelo jogador
        && !sheetChanged.hasAny(['attributes', 'job_system'])
        // Nível é controlado pelo Mestre (comparação escalar simples, sem Map==)
        && request.resource.data.character_sheet.basic_info.level
            == resource.data.character_sheet.basic_info.level;
    }

    // Compra no Bazar: bazar → requested. Restringe exatamente os campos que Bazar.jsx atualiza.
    function isPlayerBazarPurchase() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isSignedIn()
        && resource.data.status == 'bazar'
        && request.resource.data.status == 'requested'
        && request.resource.data.ownerId == request.auth.uid
        && changed.hasOnly(['status', 'ownerId', 'buyerName', 'updatedAt']);
    }

    // Sincronização de classe: atualiza campo 'class' (top-level) + character_sheet.basic_info.class
    // charId recebido como parâmetro explícito pelo mesmo motivo de escopo acima.
    function isPlayerClassSync(charId) {
      let topChanged = request.resource.data.diff(resource.data).affectedKeys();
      return isOwner(charId)
        && topChanged.hasOnly(['class', 'character_sheet'])
        && request.resource.data.character_sheet
              .diff(resource.data.character_sheet).affectedKeys().hasOnly(['basic_info'])
        && request.resource.data.character_sheet.basic_info
              .diff(resource.data.character_sheet.basic_info).affectedKeys().hasOnly(['class'])
        && request.resource.data.class is string
        && request.resource.data.class == request.resource.data.character_sheet.basic_info.class;
    }

    // Equipar do vault: restrito aos campos que Ficha.jsx atualiza no equip.
    function isPlayerEquipFromVault() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isSignedIn()
        && resource.data.status == 'vault'
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.status == 'equipped'
        && request.resource.data.ownerId == request.auth.uid
        && changed.hasOnly(['status', 'ownerId', 'buyerName', 'slotIndex', 'updatedAt']);
    }

    // Desequipar para vault: restrito aos campos que Ficha.jsx atualiza no unequip.
    function isPlayerUnequipToVault() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return isSignedIn()
        && resource.data.status == 'equipped'
        && request.resource.data.status == 'vault'
        && resource.data.ownerId == request.auth.uid
        && changed.hasOnly(['status', 'slotIndex', 'updatedAt']);
    }

    function playerCanUpdateGameItem() {
      return isPlayerBazarPurchase()
        || isPlayerEquipFromVault()
        || isPlayerUnequipToVault();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isMestre() || isAdmin();
      allow create: if isAdmin()
        && request.resource.data.uid == userId
        && request.resource.data.role in ['jogador', 'mestre']
        && request.resource.data.keys().hasAll(['email', 'role', 'uid', 'active']);
      allow update: if isAdmin()
        && request.resource.data.role in ['jogador', 'mestre']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'active']);
      allow delete: if isAdmin();
    }

    match /characters/{charId} {
      allow read: if isSignedIn();
      allow create: if isOwner(charId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasAll(['uid', 'name', 'character_sheet']);
      allow update: if isMestre()
        || isAdmin()
        || isPlayerClassSync(charId)
        || playerCanUpdateOwnCharacter(charId);
      allow delete: if isAdmin();
    }

    match /mestres_profiles/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid) && isMestre();
      allow delete: if isMestre() || isAdmin();
    }

    match /missoes/{missaoId} {
      allow read: if isSignedIn();
      allow create, delete: if isMestre();
      allow update: if isMestre()
        || (
          isSignedIn()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['candidatos'])
        );
    }

    match /sessoes/{sessaoId} {
      allow read: if isSignedIn();
      allow create, delete: if isMestre();
      allow update: if isMestre() || (isSignedIn() && playerSessionFieldsOnly());

      match /mercado_lanternas/{trocaId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.remetenteUid == request.auth.uid
          && request.resource.data.status == 'pendente_mestre';
        allow update, delete: if isMestre();
      }

      match /team_chats/{teamId}/messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn()
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.keys().hasAll(['senderName', 'senderUid', 'content', 'createdAt']);
        allow update, delete: if isMestre();
      }
    }

    match /disponibilidades/{docId} {
      allow read: if isSignedIn();
      allow write: if isMestre();
    }

    match /agenda/{docId} {
      allow read: if isSignedIn();
      allow write: if isMestre();
    }

    match /game_items/{itemId} {
      allow read: if isSignedIn();
      allow create, delete: if isMestre();
      allow update: if isMestre() || playerCanUpdateGameItem();
    }

    match /mercado_lanternas/{trocaId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.remetenteUid == request.auth.uid
        && request.resource.data.status == 'pendente_mestre';
      allow update, delete: if isMestre();
    }

    match /guild_fraternidade/{docId} {
      allow read: if isSignedIn();
      allow write: if isMestre();
    }

    match /vtt_library/{docId} {
      allow read: if isSignedIn();
      allow write: if isMestre();
    }

    match /resenhas/{docId} {
      allow read: if isSignedIn();
      allow write: if isMestre();
    }

    match /bestiary/{docId} {
      allow read: if isSignedIn();
      allow write: if isMestre();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
